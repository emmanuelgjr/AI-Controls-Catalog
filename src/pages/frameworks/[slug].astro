---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ControlCard from '../../components/ControlCard.astro';
import { getCollection } from 'astro:content';

const slugMap: Record<string, string> = {
  'iso-iec-42001': 'iso_iec_42001',
  'nist-ai-rmf': 'nist_ai_rmf',
  'eu-ai-act': 'eu_ai_act',
  'owasp-llm-top-10': 'owasp_llm_top_10',
  'owasp-agentic-top-10': 'owasp_agentic_top_10',
  'owasp-dsgai': 'owasp_dsgai',
  'mitre-atlas': 'mitre_atlas',
  'soc-2': 'soc_2',
};

export async function getStaticPaths() {
  const frameworks = await getCollection('frameworks');
  const controls = await getCollection('controls');
  return frameworks.map((f) => ({
    params: { slug: f.data.slug },
    props: { framework: f.data, allControls: controls.map((c) => c.data) },
  }));
}

const { framework, allControls } = Astro.props;
const fmKey = slugMap[framework.slug];
const matches = allControls.filter((c) => {
  const arr = (c.framework_mappings as Record<string, string[] | undefined>)[fmKey];
  return arr && arr.length > 0;
});
---

<BaseLayout
  title={`AI controls for ${framework.short_name} — AI Controls Catalog`}
  description={`${matches.length} AI controls mapped to ${framework.name}. Test procedures, evidence requirements, sample sizes.`}
>
  <section class="max-w-content mx-auto px-6 lg:px-8 py-12">
    <a href={`${import.meta.env.BASE_URL}frameworks`} class="text-sm text-ink-500 hover:text-accent-700">← All frameworks</a>
    <div class="mt-3 flex items-center gap-3">
      <span class="inline-block w-3 h-3 rounded-full" style={`background:${framework.color_mark}`}></span>
      <p class="text-sm font-medium text-accent-700">{framework.publisher}</p>
    </div>
    <h1 class="font-display font-semibold text-3xl md:text-4xl tracking-tight text-ink-900 mt-2">{framework.name}</h1>
    <p class="mt-3 text-ink-600 max-w-prose-wide">{framework.description}</p>
    <p class="mt-4 text-sm text-ink-500">
      <a href={framework.url} target="_blank" rel="noopener noreferrer" class="hover:text-accent-700">View the source →</a>
    </p>

    <h2 class="font-display font-semibold text-2xl text-ink-900 mt-12 tracking-tight">
      {matches.length} mapped controls
    </h2>
    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-6">
      {matches.map((c) => (
        <li><ControlCard control={c} /></li>
      ))}
    </ul>
  </section>
</BaseLayout>
