---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScopingWizard from '../components/ScopingWizard.tsx';
import { getCollection } from 'astro:content';

const controls = (await getCollection('controls')).map((c) => c.data);
---

<BaseLayout
  title="Scope Your Controls — AI Controls Catalog"
  description="Answer 6 questions about your AI environment to get a tailored set of audit-ready controls. Free, open-source scoping wizard."
>
  <section class="max-w-content mx-auto px-6 lg:px-8 py-12">
    <div class="mb-10 text-center">
      <p class="text-sm font-medium text-accent-700">Scoping Wizard</p>
      <h1 class="font-display font-semibold text-3xl md:text-4xl tracking-tight text-ink-900 mt-2">
        Which controls apply to you?
      </h1>
      <p class="mt-3 text-ink-600 max-w-prose-wide mx-auto">
        Answer six questions about your AI systems, regulatory environment, and
        risk priorities. The wizard scores all {controls.length} controls against your
        context and recommends a tailored set with implementation order.
      </p>
    </div>

    <ScopingWizard client:load controls={controls} />
  </section>
</BaseLayout>
