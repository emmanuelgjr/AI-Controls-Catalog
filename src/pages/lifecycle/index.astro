---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const controls = (await getCollection('controls')).map((c) => c.data);

const stages = [
  'Strategy & Planning',
  'Data Sourcing & Preparation',
  'Training',
  'Evaluation & Testing',
  'Deployment',
  'Operation & Monitoring',
  'Retirement',
];

const counts = Object.fromEntries(
  stages.map((s) => [s, controls.filter((c) => c.lifecycle_stage.includes(s as any)).length]),
);

const slugify = (s: string) =>
  s.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
---

<BaseLayout
  title="AI Lifecycle — AI Controls Catalog"
  description="Browse AI controls by lifecycle stage, from strategy and planning through retirement."
>
  <section class="max-w-content mx-auto px-6 lg:px-8 py-12">
    <p class="text-sm font-medium text-accent-700">Lifecycle</p>
    <h1 class="font-display font-semibold text-3xl md:text-4xl tracking-tight text-ink-900 mt-2">Browse by lifecycle stage</h1>
    <p class="mt-3 text-ink-600 max-w-prose-wide">
      AI risk emerges at different points across the lifecycle. Browse
      controls grouped by the stage at which they apply.
    </p>

    <ol class="mt-10 space-y-3 max-w-2xl">
      {stages.map((s, i) => (
        <li>
          <a href={`/lifecycle/${slugify(s)}`} class="card-interactive flex items-center justify-between">
            <span>
              <span class="font-mono text-xs text-ink-500">{String(i + 1).padStart(2, '0')}</span>
              <span class="ml-3 font-medium text-ink-900">{s}</span>
            </span>
            <span class="badge-neutral">{counts[s]} controls</span>
          </a>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>
