---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const controls = (await getCollection('controls')).map((c) => c.data);
const domains = ['Data', 'Model', 'Infrastructure', 'Governance', 'People & Process', 'Third Party'];

const counts = Object.fromEntries(
  domains.map((d) => [d, controls.filter((c) => c.risk_domain.includes(d as any)).length]),
);

const slugify = (s: string) =>
  s.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
---

<BaseLayout
  title="Risk Domains — AI Controls Catalog"
  description="Browse AI controls by risk domain: data, model, infrastructure, governance, people & process, third party."
>
  <section class="max-w-content mx-auto px-6 lg:px-8 py-12">
    <p class="text-sm font-medium text-accent-700">Risk domains</p>
    <h1 class="font-display font-semibold text-3xl md:text-4xl tracking-tight text-ink-900 mt-2">Browse by risk domain</h1>
    <p class="mt-3 text-ink-600 max-w-prose-wide">
      Group controls by the type of risk they address, from data and model
      risk to people, process, and third-party risk.
    </p>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-10">
      {domains.map((d) => (
        <li>
          <a href={`/risk-domains/${slugify(d)}`} class="card-interactive block">
            <h2 class="font-semibold text-ink-900">{d}</h2>
            <p class="text-sm text-ink-500 mt-1">{counts[d]} controls</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
