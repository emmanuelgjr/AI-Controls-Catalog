---
const links = [
  { href: '/controls', label: 'Controls' },
  { href: '/frameworks', label: 'Frameworks' },
  { href: '/lifecycle', label: 'Lifecycle' },
  { href: '/risk-domains', label: 'Risk' },
  { href: '/methodology', label: 'Methodology' },
  { href: '/about', label: 'About' },
];
const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-40 bg-white/80 backdrop-blur border-b border-ink-200">
  <div class="max-w-content mx-auto px-6 lg:px-8 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 font-semibold text-ink-900">
      <span class="text-accent-700">AI</span>
      <span>Controls Catalog</span>
    </a>
    <nav class="hidden md:flex items-center gap-6" aria-label="Primary">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            'text-sm font-medium hover:text-accent-700 transition-colors',
            pathname.startsWith(l.href) ? 'text-accent-700' : 'text-ink-700',
          ]}
        >
          {l.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <a
        href="https://github.com/emmanuelgjr/AI-Controls-Catalog"
        class="btn btn-secondary btn-sm"
        aria-label="View on GitHub"
      >
        GitHub
      </a>
    </div>
  </div>
</header>
