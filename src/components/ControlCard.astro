---
import FrameworkBadge from './FrameworkBadge.astro';
import type { Control } from '../content/config';

interface Props {
  control: Control;
}

const { control } = Astro.props;
const mappings = control.framework_mappings ?? {};
const frameworkKeys = Object.entries(mappings)
  .filter(([, v]) => v && (v as string[]).length > 0)
  .map(([k]) => k);
---

<a href={`/controls/${control.id}`} class="card-interactive block group">
  <div class="flex items-start justify-between mb-3 gap-3">
    <div>
      <p class="font-mono text-xs text-ink-500">{control.id}</p>
      <h3 class="text-lg font-semibold text-ink-900 group-hover:text-accent-700 transition-colors mt-1">
        {control.title}
      </h3>
    </div>
    <span class="badge-neutral whitespace-nowrap">{control.control_type}</span>
  </div>

  <p class="text-sm text-ink-600 mb-4 line-clamp-3">{control.objective}</p>

  <div class="flex flex-wrap gap-1.5 mb-3">
    <span class="badge-accent">{control.category}</span>
  </div>

  <div class="flex flex-wrap gap-1.5">
    {frameworkKeys.slice(0, 4).map((k) => <FrameworkBadge framework={k} />)}
    {frameworkKeys.length > 4 && (
      <span class="badge-neutral">+{frameworkKeys.length - 4}</span>
    )}
  </div>

  <div class="mt-4 pt-3 border-t border-ink-100 text-xs text-ink-500 flex items-center justify-between">
    <span>v{control.version}</span>
    <span>Reviewed {control.last_reviewed}</span>
  </div>
</a>
